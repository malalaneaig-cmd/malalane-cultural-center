# Vercel deployment — no environment variables required for the static site.
# Run `npm run assets` once to download logo images into public/images/.

# Optional — override the default FormSubmit endpoint (defaults to info@malalane.org)
# VITE_CONTACT_FORM_ENDPOINT=https://formsubmit.co/ajax/info@malalane.org

# Donation checkout URL (PayPal, Stripe, CanadaHelps, etc.)
# Use {amount} where the selected dollar amount should go. Example PayPal.me:
# VITE_DONATION_URL=https://paypal.me/yourorg/{amount}USD
# Example Stripe Payment Link (fixed tiers — amount is appended as a hint):
# VITE_DONATION_URL=https://buy.stripe.com/your-link-here

# Legacy Spaceship FTP (only for deploy:spaceship)
# FTP_SERVER="server702.shared.spaceship.host"
# FTP_USERNAME="website@malalane.org"
# FTP_PASSWORD="your-ftp-password-here"
# FTP_PORT="21"
# FTP_EXPLICIT_FTPS="true"
