# Vercel deployment — no environment variables required for the static site.
# Run `npm run assets` once to download logo images into public/images/.

# Optional (future integrations)
# VITE_CONTACT_FORM_ENDPOINT=
# VITE_DONATION_URL=

# Legacy Spaceship FTP (only for deploy:spaceship)
# FTP_SERVER="server702.shared.spaceship.host"
# FTP_USERNAME="website@malalane.org"
# FTP_PASSWORD="your-ftp-password-here"
# FTP_PORT="21"
# FTP_EXPLICIT_FTPS="true"
